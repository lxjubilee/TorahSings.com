# Copy to .env and fill in. One file holds every local credential (the web app
# and the local auth server both read .env). .env is gitignored; this .env.example
# is the only committed env file, so it must never hold a real value.
#
# Secrets have NO fallback in source — a default secret written into code is a
# public secret. Anything marked "required" makes the local auth server refuse
# to start when unset, rather than sign tokens with something everyone can read.

# ---- Local auth server (scripts/local-auth-server.mjs) ---------------------
# Only needed for local dev; `npm run dev` starts that server. Generate each:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"

# required — HMAC secret signing local access/refresh tokens. Rotating it signs
# everyone out (passwords are scrypt and unaffected).
JWT_SECRET=

# required — Bearer token for the service-to-service routes
# (GET /api/auth/admin/check-email). Local stand-in for the production API's
# client-credentials JWT. Never ship this to a browser.
LOCAL_SERVICE_TOKEN=

# Port the local auth server listens on. Default 4031; match NEXT_PUBLIC_API_BASE.
PORT=

# ---- Identity API (sign in / sign up) --------------------------------------
# next.config.mjs rewrites the browser's same-origin /api/* to this host, so the
# API hostname never reaches the client bundle and there is no CORS preflight.
# Unset => https://api.torahsings.com.
#
# torahsings-api is built but NOT deployed yet (docs/AUTH_API.md). The identical
# endpoints are live on Jubilujah today, so to exercise sign-up/sign-in now:
#   NEXT_PUBLIC_API_BASE=https://api.jubilujah.com
NEXT_PUBLIC_API_BASE=

# ---- Jubilee Account SSO ---------------------------------------------------
# Unset => src/lib/jubilee-account.tsx runs its local stub session.
NEXT_PUBLIC_JUBILEE_SSO_URL=

# ---- Cloudflare Turnstile (sign-in CAPTCHA) --------------------------------
# Public site key — rendered by the browser. Blank => the sign-in page renders
# no Turnstile widget (dev). The widget's Cloudflare config must list every
# hostname it will render on (torahsings.com, localhost).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Secret half of the same key pair, used by /api/turnstile/verify for the
# siteverify call. Blank => verification is skipped and the widget is
# decorative. Never expose this to the browser.
TURNSTILE_SECRET_KEY=
