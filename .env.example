# Copy to .env.local and fill in. .env.local is gitignored.

# ---- Jubilee Account SSO ---------------------------------------------------
# Unset => src/lib/jubilee-account.tsx runs its local stub session.
NEXT_PUBLIC_JUBILEE_SSO_URL=

# ---- Cloudflare Turnstile (sign-in CAPTCHA) --------------------------------
# Public site key — rendered by the browser. Blank => the sign-in page renders
# no Turnstile widget (dev). The widget's Cloudflare config must list every
# hostname it will render on (torahsings.com, localhost).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Secret half of the same key pair, used by /api/turnstile/verify for the
# siteverify call. Blank => verification is skipped and the widget is
# decorative. Never expose this to the browser.
TURNSTILE_SECRET_KEY=
